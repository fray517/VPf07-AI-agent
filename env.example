# Скопируйте в agent/.env и укажите значения.
OPENAI_API_KEY=

# Telegram-бот (python run_bot.py)
TELEGRAM_BOT_TOKEN=
# Необязательно: gpt-4o-mini, gpt-4o, gpt-3.5-turbo и т.д.
OPENAI_MODEL=gpt-4o-mini

# Логи: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Путь к файлу логов (по умолчанию agent/agent.log)
# LOG_FILE=

# Макс. шагов графа (вызовы модели/инструментов; по умолчанию 12)
# AGENT_RECURSION_LIMIT=12
